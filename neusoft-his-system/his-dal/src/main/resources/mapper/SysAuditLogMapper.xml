<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neusoft.his.dal.mapper.SysAuditLogMapper">

    <select id="selectAuditPage" resultType="com.neusoft.his.dal.entity.SysAuditLog">
        SELECT id, time, username, operation, detail
        FROM sys_audit_log
        ORDER BY time DESC
    </select>

    <select id="countAuditPage" resultType="long">
        SELECT COUNT(1)
        FROM sys_audit_log
    </select>
</mapper>
